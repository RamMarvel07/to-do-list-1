rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'userId', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 500 &&
             (data.get('description', '') is string && data.get('description', '').size() <= 2000) &&
             (data.get('completed', false) is bool) &&
             (data.get('category', 'Personal') is string && data.get('category', 'Personal').size() <= 50) &&
             (data.get('priority', 'Medium') in ['Low', 'Medium', 'High']) &&
             (data.get('order', 0) is number) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(taskId) && 
                    isValidTask(incoming()) &&
                    incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && 
                    existing().userId == request.auth.uid &&
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (
                      // Action: Toggle completion
                      (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt'])) ||
                      // Action: Edit content
                      (incoming().diff(existing()).affectedKeys().hasAll(['title', 'updatedAt']) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'priority', 'dueDate', 'updatedAt'])) ||
                      // Action: Reorder
                      (incoming().diff(existing()).affectedKeys().hasOnly(['order', 'updatedAt']))
                    );
      
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) &&
                            incoming().keys().hasAll(['displayName', 'photoURL', 'email']) &&
                            incoming().email == request.auth.token.email;
    }
  }
}
